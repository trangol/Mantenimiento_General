rules_version = '2';

// ============================================================
// MantOS — Reglas de seguridad Firestore (multi-tenant)
//
// MODELO: todos los documentos llevan `tenantId`. Un usuario solo
// puede leer/escribir documentos de SU tenant. El tenantId del
// usuario vendrá del custom claim `tenantId` en su token de auth
// (request.auth.token.tenantId), que se asigna al crear el usuario
// con firebase-admin (setCustomUserClaims).
//
// MODO DESARROLLO: mientras el módulo de autenticación no esté
// desplegado, devMode() = true permite acceso, PERO exige que toda
// escritura lleve tenantId válido (formato TEN-...). Antes de pasar
// a producción: cambiar devMode() a `return false;` y desplegar:
//   firebase deploy --only firestore:rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----------------------------------------------------
    function devMode() {
      // TODO PRODUCCIÓN: cambiar a false cuando exista Firebase Auth
      return true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function userTenant() {
      return request.auth.token.tenantId;
    }

    function hasValidTenant(data) {
      return data.tenantId is string && data.tenantId.matches('TEN-[0-9A-Z]{4,16}');
    }

    // Lectura: doc del mismo tenant (o legado sin tenantId, solo dev)
    function canRead() {
      return devMode()
        || (isSignedIn() && resource.data.tenantId == userTenant());
    }

    // Creación: el dato DEBE llevar tenantId válido y (con auth) coincidir
    function canCreate() {
      return hasValidTenant(request.resource.data)
        && (devMode() || (isSignedIn() && request.resource.data.tenantId == userTenant()));
    }

    // Actualización: no se permite CAMBIAR el tenantId de un documento
    function canUpdate() {
      return request.resource.data.tenantId == resource.data.tenantId
        && (devMode() || (isSignedIn() && resource.data.tenantId == userTenant()));
    }

    function canDelete() {
      return devMode()
        || (isSignedIn() && resource.data.tenantId == userTenant());
    }

    // ---- Colecciones operativas (todas tenant-scoped) ----------------
    match /clients/{id}              { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /assets/{id}               { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /maintenance_records/{id}  { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /inventory/{id}            { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /stock_movements/{id}      { allow read: if canRead(); allow create: if canCreate(); allow update: if false; allow delete: if false; } // movimientos: inmutables (auditoría)
    match /quotes/{id}               { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /invoices/{id}             { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /vehicles/{id}             { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /routes/{id}               { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /recurring_schedules/{id}  { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /team/{id}                 { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }
    match /service_requests/{id}     { allow read: if canRead(); allow create: if canCreate(); allow update: if canUpdate(); allow delete: if canDelete(); }

    // Tenants: solo lectura del propio (admin vía backend)
    match /tenants/{tenantId} {
      allow read: if devMode() || (isSignedIn() && userTenant() == tenantId);
      allow write: if devMode(); // en prod: solo backend con admin SDK
    }

    // Todo lo no listado: denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
